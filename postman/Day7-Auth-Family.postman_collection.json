{
  "info": {
    "name": "Day7 Auth + Family QA",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "ownerEmail", "value": "owner@example.com" },
    { "key": "viewerEmail", "value": "viewer@example.com" },
    { "key": "password", "value": "password123" },
    { "key": "ownerToken", "value": "" },
    { "key": "viewerToken", "value": "" },
    { "key": "inviteId", "value": "" },
    { "key": "viewerUserId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Register Owner",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Owner User\",\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"owner\"\n}"
        }
      }
    },
    {
      "name": "Register Viewer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Viewer User\",\n  \"email\": \"{{viewerEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"viewer\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "if (pm.response.code === 201) {",
            "  const res = pm.response.json();",
            "  pm.collectionVariables.set('viewerUserId', res.user.id);",
            "}"
          ]
        }
      }]
    },
    {
      "name": "Login Owner",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const res = pm.response.json();",
            "if (res.token) pm.collectionVariables.set('ownerToken', res.token);"
          ]
        }
      }]
    },
    {
      "name": "Invite Viewer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
        ],
        "url": "{{baseUrl}}/api/family/invite",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{viewerEmail}}\",\n  \"role\": \"viewer\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const res = pm.response.json();",
            "if (res.invite && res.invite.id) pm.collectionVariables.set('inviteId', res.invite.id);"
          ]
        }
      }]
    },
    {
      "name": "Login Viewer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{viewerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const res = pm.response.json();",
            "if (res.token) pm.collectionVariables.set('viewerToken', res.token);",
            "if (res.user && res.user.id) pm.collectionVariables.set('viewerUserId', res.user.id);"
          ]
        }
      }]
    },
    {
      "name": "Accept Invite",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{viewerToken}}" }],
        "url": "{{baseUrl}}/api/family/accept/{{inviteId}}"
      }
    },
    {
      "name": "List Family (Owner)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
        "url": "{{baseUrl}}/api/family/mine"
      }
    },
    {
      "name": "List Family (Viewer)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{viewerToken}}" }],
        "url": "{{baseUrl}}/api/family/mine"
      }
    },
    {
      "name": "Remove Viewer",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
        "url": "{{baseUrl}}/api/family/member/{{viewerUserId}}"
      }
    }
  ]
}
