{
  "name": "diabetes-app-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "worker"
  ],
  "scripts": {
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "dev:worker": "npm run dev -w worker",
    "build": "npm run build -w client && npm run build -w server && npm run build -w worker",
    "lint": "npm run lint -w client && npm run lint -w server && npm run lint -w worker",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
